{
  "name": "@deverjak/tenantkit-testing",
  "version": "0.2.0",
  "description": "The in-memory adapter + port conformance suite for the tenantkit kernel — the 'is it really decoupled?' honesty check (docs/14 §6.4). Vendor-free CoreRuntime for fast tests + reusable vitest suites every adapter must pass.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./conformance": "./src/conformance.ts"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./conformance": {
        "types": "./dist/conformance.d.ts",
        "import": "./dist/conformance.js"
      }
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@deverjak/tenantkit-kernel": "workspace:*"
  },
  "peerDependencies": {
    "vitest": ">=3"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  }
}
