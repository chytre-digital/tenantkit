{
  "name": "@deverjak/tenantkit-reservation-core",
  "version": "0.1.0",
  "description": "Layer-2 reservation domain on @deverjak/tenantkit-kernel: pure courses/sessions/capacity logic, the enrollment rules, and the omluvenka (excuse -> makeup-credit -> redeem) engine. Vendor-free, no I/O.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./credits": "./src/credits/index.ts",
    "./courses": "./src/courses/index.ts",
    "./enrollment": "./src/enrollment/index.ts"
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
      "./credits": { "types": "./dist/credits/index.d.ts", "import": "./dist/credits/index.js" },
      "./courses": { "types": "./dist/courses/index.d.ts", "import": "./dist/courses/index.js" },
      "./enrollment": { "types": "./dist/enrollment/index.d.ts", "import": "./dist/enrollment/index.js" }
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "tsc -p tsconfig.build.json --outDir dist --declaration"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  }
}
